{
  "compilerOptions": {
    "declaration": true,
    "esModuleInterop": true,
    "module": "commonjs",
    "noEmit": true,
    "rootDir": ".",
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "target": "es2020",
    "useUnknownInCatchVariables": false
  },
  "exclude": [
    "node_modules",
    "dist",
    "coverage",
    ".nyc_output",
    ".git"
  ],
  "include": [
    "src/**/*",
    "test/**/*"
  ]
}
